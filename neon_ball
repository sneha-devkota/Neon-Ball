<div style="text-align:center; font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; position: relative; width: 320px; margin: auto;">
    
    <div id="ui" style="position: absolute; width: 100%; top: 120px; z-index: 10; background: rgba(255,255,255,0.1); backdrop-filter: blur(5px); padding: 20px 0; border-radius: 15px;">
        <h1 id="headerText" style="color: white; text-shadow: 2px 4px 10px rgba(0,0,0,0.3); margin: 0; letter-spacing: 2px;">NEON BALL</h1>
        <p id="scoreInfo" style="color: #FFD700; font-weight: bold; font-size: 1.2rem; margin: 10px 0;">BEST: 0</p>
        <button id="startBtn" onclick="startGame()" style="padding: 12px 30px; font-size: 18px; cursor: pointer; background: #2ecc71; color: white; border: none; border-radius: 50px; font-weight: bold; box-shadow: 0 4px 15px rgba(46, 204, 113, 0.4); transition: 0.3s;">START GAME</button>
    </div>
    
    <canvas id="c" width="320" height="480" style="border-radius:15px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: block;"></canvas>
    
    <div style="background: #222; color: white; padding: 15px; border-bottom-left-radius: 15px; border-bottom-right-radius: 15px; display: flex; justify-content: space-between; align-items: center;">
        <h3 id="s" style="margin:0; color: #2ecc71;">Score: 0</h3>
        <span id="sp" style="font-size: 12px; color: #888;">Speed: 1.0x</span>
    </div>
</div>

<script>
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    const scoreLabel = document.getElementById('s');
    const speedLabel = document.getElementById('sp');
    const headerText = document.getElementById('headerText');
    const scoreInfo = document.getElementById('scoreInfo');
    const startBtn = document.getElementById('startBtn');
    const ui = document.getElementById('ui');

    let highScore = localStorage.getItem('flappyHighScore') || 0;
    scoreInfo.innerText = "BEST: " + highScore;

    let gravity = 0.22, jumpForce = -4.8, initialGameSpeed = 2.5, gameSpeed = initialGameSpeed, pipeGap = 150;
    let birdY = 240, birdV = 0, score = 0, pipes = [];
    let gameStarted = false, gameActive = false, isGameOver = false;

    function resetGameState() {
        birdY = 240;
        birdV = 0;
        score = 0;
        pipes = [];
        gameSpeed = initialGameSpeed;
        
        scoreLabel.innerText = "Score: 0";
        speedLabel.innerText = "Speed: 1.0x";
    }

    function startGame() {
        if (!gameStarted) { // First time setup
            jump(); // Make an initial jump
            window.addEventListener('keydown', (e) => { if(e.code === 'Space') jump(); });
            canvas.addEventListener('mousedown', jump);
            gameStarted = true;
            gameLoop(); // Start the loop
        } else if (isGameOver) {
            resetGameState();
        }

        ui.style.display = "none";
        gameActive = true;
        isGameOver = false;
    }

    function jump() {
        if(gameActive && gameStarted) birdV = jumpForce;
    }

    function drawBackground() {
        // Sky Gradient
        let sky = ctx.createLinearGradient(0, 0, 0, canvas.height);
        sky.addColorStop(0, '#4facfe');
        sky.addColorStop(1, '#00f2fe');
        ctx.fillStyle = sky;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Drawing a Sun
        ctx.fillStyle = "rgba(255, 255, 255, 0.3)";
        ctx.beginPath();
        ctx.arc(260, 60, 40, 0, Math.PI * 2);
        ctx.fill();
    }

    function gameLoop() {
        if (!gameStarted) return; // Exit if game never ran

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        drawBackground();

        if (gameActive) {
            birdV += gravity;
            birdY += birdV;

            if (pipes.length === 0 || pipes[pipes.length - 1].x < 160) {
                let pY = Math.random() * (canvas.height - pipeGap - 100) + 50;
                pipes.push({ x: 320, y: pY, passed: false });
            }
        }

        // Draw Ball with Glow
        ctx.shadowBlur = 15;
        ctx.shadowColor = "#FF5733";
        ctx.fillStyle = "#FF5733";
        ctx.beginPath();
        ctx.arc(60, birdY, 12, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0; // Reset shadow

        // Draw Pipes with Gradients
        for (let i = pipes.length - 1; i >= 0; i--) {
            let p = pipes[i];
            if (gameActive) p.x -= gameSpeed;

            let pipeGrad = ctx.createLinearGradient(p.x, 0, p.x + 50, 0);
            pipeGrad.addColorStop(0, '#2ecc71');
            pipeGrad.addColorStop(1, '#27ae60');
            ctx.fillStyle = pipeGrad;

            // Top Pipe
            ctx.fillRect(p.x, 0, 50, p.y);
            // Bottom Pipe
            ctx.fillRect(p.x, p.y + pipeGap, 50, canvas.height);

            // Collision Check
            if (gameActive && (60 + 10 > p.x && 60 - 10 < p.x + 50)) {
                if (birdY - 10 < p.y || birdY + 10 > p.y + pipeGap) die();
            }

            // Score Check
            if (gameActive && (p.x + 50 < 60 && !p.passed)) {
                score++;
                p.passed = true;
                gameSpeed += 0.12;
                scoreLabel.innerText = "Score: " + score;
                speedLabel.innerText = "Speed: " + (gameSpeed/2.5).toFixed(1) + "x";
                if (score > highScore) {
                    highScore = score;
                    localStorage.setItem('flappyHighScore', highScore);
                    scoreInfo.innerText = "BEST: " + highScore;
                }
            }
            if (p.x < -60) pipes.splice(i, 1);
        }

        // Ground/Ceiling Check
        if (gameActive && (birdY > canvas.height || birdY < 0)) die();

        requestAnimationFrame(gameLoop);
    }

    function die() {
        gameActive = false;
        isGameOver = true;
        
        // Update UI to reflect Game Over state
        headerText.innerText = "GAME OVER";
        headerText.style.color = "#e74c3c"; // Reddish color for Game Over
        headerText.style.textShadow = "2px 4px 10px rgba(0,0,0,0.5)";
        
        scoreInfo.innerText = "SCORE: " + score + " | BEST: " + highScore;
        scoreInfo.style.color = "white";

        startBtn.innerText = "RESTART";
        startBtn.style.background = "#e74c3c"; // Change button color
        startBtn.style.boxShadow = "0 4px 15px rgba(231, 76, 60, 0.4)";
        
        ui.style.display = "block";
    }

    // Pre-draw the background so it's visible before start
    drawBackground();
</script>
